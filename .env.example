EXPO_PUBLIC_SUPABASE_URL=your_supabase_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Reporter de erros (Sentry) — opcional. Se vazio, errorReporter vira no-op.
# Necessário apenas após `npm i @sentry/react-native` ser aprovado.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENV=development

# Sugestão de preço por IA (M1-23) — opcional.
# Default: derivado de EXPO_PUBLIC_SUPABASE_URL → /functions/v1/suggest-price
# Sobrescreva apenas se quiser apontar para outro proxy/host.
# A chave da Anthropic NUNCA fica no app; configure no Supabase com:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
EXPO_PUBLIC_AI_PROXY_URL=
